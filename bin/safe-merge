#!/usr/bin/env bash
# safe-merge: merge a PR only after all CI checks have passed.
# Discipline-only — GitHub Free private repos can't enforce required checks
# server-side, so this wrapper enforces it client-side.
#
# Usage:
#   bin/safe-merge              # merges the PR for the current branch
#   bin/safe-merge 7            # merges PR #7
#   bin/safe-merge 7 --rebase   # extra args forwarded to `gh pr merge`
set -euo pipefail

PR="${1:-}"
EXTRA_ARGS=()

if [ -n "$PR" ] && [[ "$PR" =~ ^[0-9]+$ ]]; then
  shift
  EXTRA_ARGS=("$@")
else
  EXTRA_ARGS=("$@")
  PR=$(gh pr view --json number --jq .number 2>/dev/null || true)
  if [ -z "$PR" ]; then
    echo "safe-merge: pass a PR number, or run from a branch with an open PR." >&2
    exit 1
  fi
fi

echo "safe-merge: watching CI for PR #$PR (waits if still running)..."
if ! gh pr checks "$PR" --watch --fail-fast; then
  echo "safe-merge: at least one check failed. Not merging." >&2
  exit 1
fi

echo "safe-merge: all checks passed. Merging PR #$PR (squash + delete branch)..."
gh pr merge "$PR" --squash --delete-branch "${EXTRA_ARGS[@]}"
