#!/usr/bin/env bash
# Append a context entry to CHANGELOG.md and amend it into HEAD so the changelog
# lands in the same commit as the work it describes. CHANGELOG_HOOK_SKIP guards
# against recursion (--no-verify only skips pre-commit + commit-msg).
set -euo pipefail

if [ -n "${CHANGELOG_HOOK_SKIP:-}" ]; then
  exit 0
fi

if [ -d .git/rebase-merge ] || [ -d .git/rebase-apply ] \
    || [ -f .git/MERGE_HEAD ] || [ -f .git/CHERRY_PICK_HEAD ]; then
  exit 0
fi

SUBJECT=$(git log -1 --pretty=%s)
[ -z "$SUBJECT" ] && exit 0

CHANGELOG="CHANGELOG.md"
TIMESTAMP=$(git log -1 --pretty=%ad --date=format:'%Y-%m-%d %H:%M %z')
FILES=$(git show --name-only --diff-filter=ACMRTD --pretty=format: HEAD \
        | grep -v '^CHANGELOG\.md$' | grep -v '^$' || true)

# If only CHANGELOG.md changed in this commit (e.g. someone committed CHANGELOG
# manually), don't amend — there's nothing new to journal.
[ -z "$FILES" ] && exit 0

if [ ! -f "$CHANGELOG" ]; then
  printf "# Changelog\n\nAuto-generated context log for vibe-coded commits.\n\n" > "$CHANGELOG"
fi

{
  printf "## %s — %s\n\n" "$TIMESTAMP" "$SUBJECT"
  printf "Files touched:\n"
  while IFS= read -r f; do
    printf -- "- \`%s\`\n" "$f"
  done <<< "$FILES"
  printf "\n"
} >> "$CHANGELOG"

git add "$CHANGELOG"
CHANGELOG_HOOK_SKIP=1 git commit --amend --no-edit --no-verify >/dev/null
