#!/usr/bin/env bash
set -euo pipefail

CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
if [ "$CURRENT_BRANCH" = "main" ]; then
  cat >&2 <<EOF
pre-commit: direct commits to 'main' are blocked.

  → Create a feature branch:   git switch -c feat/your-change
  → Push it:                   git push -u origin feat/your-change
  → Open a PR + let CI run:    gh pr create --fill
  → Merge via the GitHub UI once green.
EOF
  exit 1
fi

STAGED_PHP=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.php$' || true)
STAGED_TS=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx)$' || true)

[ -z "$STAGED_PHP" ] && [ -z "$STAGED_TS" ] && exit 0

if ! docker compose ps --status running --services 2>/dev/null | grep -qx 'app'; then
  echo "pre-commit: sail not running — run './vendor/bin/sail up -d'" >&2
  exit 1
fi

if [ -n "$STAGED_PHP" ]; then
  # shellcheck disable=SC2086
  ./vendor/bin/sail exec -T app ./vendor/bin/pint $STAGED_PHP
  # shellcheck disable=SC2086
  git add $STAGED_PHP
  # phpstan + tsc run full — partial checks miss cross-file errors.
  ./vendor/bin/sail exec -T app ./vendor/bin/phpstan analyse --no-progress
  # shellcheck disable=SC2086
  ./vendor/bin/sail exec -T app ./vendor/bin/rector --dry-run --no-progress-bar $STAGED_PHP
fi

if [ -n "$STAGED_TS" ]; then
  # tsc + eslint both run full (not staged-only): partial eslint missed
  # cross-file/pre-existing errors and let 2 lint errors reach main.
  ./vendor/bin/sail exec -T app npm run typecheck
  ./vendor/bin/sail exec -T app npm run lint
fi
