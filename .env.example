APP_NAME=TemanLari
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_ANALYTICS_DATABASE=teman_lari_analytics
DB_DATABASE=teman_lari
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# === Sail container file ownership (host UID/GID match) ===
# Run `id -u` and `id -g` on your host to fill these
WWWUSER=1000
WWWGROUP=1000

# === Logging ===
LOG_DAILY_DAYS=14

# === Host-forwarded ports (7000-range to avoid clashes) ===
APP_PORT=7001
VITE_PORT=7002
FORWARD_DB_PORT=7003
FORWARD_REDIS_PORT=7004

# === PRODUCTION OVERRIDES (set in your deploy environment, do NOT commit values) ===
# LOG_CHANNEL=stderr       # if your runtime aggregates stderr; no filesystem writes
# LOG_LEVEL=info
# APP_DEBUG=false
# APP_ENV=production
# FILESYSTEM_DISK=s3

# === Strava (OAuth + webhook ingest) ===
# Create an API application at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# A secret string you invent (e.g. `openssl rand -hex 24`), echoed back to Strava
# during the push-subscription handshake. Must match the token passed to
# `php artisan strava:webhook-subscribe --action=create`.
STRAVA_WEBHOOK_VERIFY_TOKEN=
# Returned by Strava after the subscription is created; set it so you can later
# run `--action=view|delete`. Leave empty until then.
STRAVA_WEBHOOK_SUBSCRIPTION_ID=

# === Azure OpenAI (Temari LLM narration) ===
# Empty URI/key disables LLM narration: Analysis rows stay pending, no tokens spent.
AZURE_OPENAI_URI=
AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_TIMEOUT=15

# === AI narration pipeline tuning (optional, defaults shown) ===
# AI_AUTO_DISPATCH=true
# AI_QUEUE=default
# AI_COOLDOWN_SECONDS=300
# AI_RATE_LIMIT_PER_MINUTE=8
# AI_BACKFILL_THRESHOLD_HOURS=24
# AI_BACKFILL_STAGGER_SECONDS=360

# === Feature flags (QA / demo) ===
DEMO_LOGIN_ENABLED=false
