# TLS terminates at Cloudflare; this listener is plain HTTP behind the tunnel.
{
	auto_https off
	frankenphp {
		# Recycle each worker after a bounded number of requests to cap
		# per-request memory growth (leak → OOM at the 1g container cap).
		# Octane's frankenphp-worker.php loop reads MAX_REQUESTS
		# from the worker env (default 1000); `num 2` sets the 2-worker sizing
		# independent of host core count.
		worker {
			file /var/www/html/public/frankenphp-worker.php
			num 2
			env MAX_REQUESTS 2000
		}
	}
	admin off
	servers {
		trusted_proxies static private_ranges
	}
}

:7001 {
	root * /var/www/html/public
	# Cloudflare re-compresses at the edge with brotli, so brotli on the
	# origin is wasted CPU. zstd for tunnel transport, gzip as fallback.
	encode zstd gzip

	# `handle` blocks (not free-standing directives) — php_server's worker
	# chain bypasses Caddy's middleware ordering otherwise, so cache headers on
	# free-standing matchers were silently dropped.
	@vite path /build/*
	handle @vite {
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	@static path /favicon.ico /favicon.svg /robots.txt /apple-touch-icon.png /icon-192.png /icon-512.png /icon-maskable-512.png
	handle @static {
		header Cache-Control "public, max-age=604800"
		file_server
	}

	# Service worker: never long-cache it, or an updated sw.js serves stale and the
	# push handler never refreshes. At the site root so its scope is the whole app.
	@sw path /sw.js
	handle @sw {
		header Cache-Control "no-cache"
		header Content-Type "text/javascript"
		file_server
	}

	# Web app manifest: Caddy has no .webmanifest MIME entry, so set it explicitly
	# (iOS rejects a mis-typed manifest).
	@manifest path /manifest.webmanifest
	handle @manifest {
		header Cache-Control "public, max-age=604800"
		header Content-Type "application/manifest+json"
		file_server
	}

	# Ops dashboards (/horizon, /pulse, /ai-usage) authorize inside Laravel via
	# `is_admin`; Cloudflare Access fronts the edge. No basic-auth wall here.
	handle {
		header -Server
		# Security response headers for the app HTML. HSTS is set at the Cloudflare
		# edge (this origin listener is plain HTTP behind the tunnel), so it is
		# intentionally not here. No public page is meant to be framed — card sharing
		# is a rendered PNG (og:image), not an embeddable iframe — so DENY is safe.
		header X-Frame-Options "DENY"
		header X-Content-Type-Options "nosniff"
		header Referrer-Policy "strict-origin-when-cross-origin"
		# Enforced. The two runtime origins report-only surfaced are gone: mdi icons
		# are bundled offline (no api.iconify.design fetch) and Cloudflare Web
		# Analytics is disabled (no injected beacon/inline script). unsafe-inline is
		# for lib-injected <style>; fonts via Google Fonts; img https: for OSM tiles.
		header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'; worker-src 'self'; manifest-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"
		php_server
	}
}
