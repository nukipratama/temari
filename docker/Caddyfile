# TLS terminates at Cloudflare; this listener is plain HTTP behind the tunnel.
{
	auto_https off
	frankenphp {
		worker /var/www/html/public/frankenphp-worker.php
	}
	admin off
	servers {
		trusted_proxies static private_ranges
	}
}

:7001 {
	root * /var/www/html/public
	# Cloudflare re-compresses at the edge with brotli, so brotli on the
	# origin is wasted CPU. zstd for tunnel transport, gzip as fallback.
	encode zstd gzip

	# `handle` blocks (not free-standing directives) — php_server's worker
	# chain bypasses Caddy's middleware ordering otherwise, which silently
	# skipped basicauth on /horizon and /pulse when it was free-standing.
	@vite path /build/*
	handle @vite {
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	@static path /favicon.ico /favicon.svg /robots.txt /apple-touch-icon.png
	handle @static {
		header Cache-Control "public, max-age=604800"
		file_server
	}

	# Edge basic auth for ops dashboards (defense-in-depth behind Cloudflare
	# Access). Lives outside Laravel so bots/scrapers never even boot the app.
	# User + bcrypt hash come from /opt/teman-lari/.env on the host
	# (DEVTOOLS_BASIC_AUTH_USER / DEVTOOLS_BASIC_AUTH_PASS_HASH).
	# Generate the hash with `caddy hash-password`.
	@devtools path /horizon* /pulse* /ai-usage*
	handle @devtools {
		basicauth {
			{$DEVTOOLS_BASIC_AUTH_USER} {$DEVTOOLS_BASIC_AUTH_PASS_HASH}
		}
		header -Server
		php_server
	}

	handle {
		header -Server
		php_server
	}
}
