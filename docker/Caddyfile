# FrankenPHP serves the Laravel app on :7001 (matches the project's 7xxx
# host-port convention). Cloudflare Tunnel terminates TLS at the edge and
# proxies plain HTTP into the container, so auto_https is disabled here.
{
	auto_https off
	frankenphp {
		# Octane-driven worker mode: PHP boots once per worker, then handles
		# requests in a loop. Worker count comes from FRANKENPHP_NUM_WORKERS
		# (env in compose.prod.yaml). Stub at public/frankenphp-worker.php
		# is generated by `php artisan octane:install --server=frankenphp`.
		worker /app/public/frankenphp-worker.php
	}
	admin off
	servers {
		trusted_proxies static private_ranges
	}
}

:7001 {
	root * /app/public
	encode zstd br gzip

	# Per-path `handle` blocks instead of free-standing `header` directives:
	# the latter don't reliably reach the wire when `php_server` runs after
	# them — the worker chain bypasses Caddy's response-header middleware.
	# `handle` terminates the request inside the block, so headers + the
	# bound file_server are guaranteed to compose.

	@vite path /build/*
	handle @vite {
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	@static path /favicon.ico /favicon.svg /robots.txt /apple-touch-icon.png
	handle @static {
		header Cache-Control "public, max-age=604800"
		file_server
	}

	handle {
		header -Server
		php_server
	}
}
