# TLS terminates at Cloudflare; this listener is plain HTTP behind the tunnel.
{
	auto_https off
	frankenphp {
		worker /app/public/frankenphp-worker.php
	}
	admin off
	servers {
		trusted_proxies static private_ranges
	}
}

:7001 {
	root * /app/public
	encode zstd br gzip

	# `handle` blocks (not free-standing `header`) — php_server's worker
	# chain bypasses Caddy's response-header middleware otherwise.
	@vite path /build/*
	handle @vite {
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	@static path /favicon.ico /favicon.svg /robots.txt /apple-touch-icon.png
	handle @static {
		header Cache-Control "public, max-age=604800"
		file_server
	}

	handle {
		header -Server
		php_server
	}
}
