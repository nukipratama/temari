<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Unit-Services-Run">
            <directory>tests/Unit/Services/Run</directory>
            <directory>tests/Unit/Services/Weather</directory>
            <directory>tests/Unit/Services/Geo</directory>
        </testsuite>
        <testsuite name="Unit-Services-AI">
            <directory>tests/Unit/Services/AI</directory>
        </testsuite>
        <testsuite name="Unit-Other">
            <directory>tests/Unit/Services/Gamification</directory>
            <directory>tests/Unit/Services/Strava</directory>
            <directory>tests/Unit/Services/Telegram</directory>
            <directory>tests/Unit/Services/Docs</directory>
            <directory>tests/Unit/Jobs</directory>
            <directory>tests/Unit/Models</directory>
            <directory>tests/Unit/Console</directory>
            <directory>tests/Unit/Listeners</directory>
            <directory>tests/Unit/Enums</directory>
            <directory>tests/Unit/Exceptions</directory>
            <directory>tests/Unit/Http</directory>
            <directory>tests/Unit/Policies</directory>
            <directory>tests/Unit/Providers</directory>
            <directory>tests/Unit/Support</directory>
            <directory>tests/Unit/Seeders</directory>
            <directory>tests/Unit/Architecture</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_KEY" value="base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="mysql"/>
        <env name="DB_HOST" value="mysql_test"/>
        <env name="DB_PORT" value="3306"/>
        <env name="DB_DATABASE" value="teman_lari_testing"/>
        <!-- analytics connection co-locates in the default test DB; TestCase
             re-points it at the per-process DB before RefreshDatabase boots. -->
        <env name="DB_ANALYTICS_DATABASE" value="teman_lari_testing"/>
        <env name="DB_USERNAME" value="sail"/>
        <env name="DB_PASSWORD" value="password"/>
        <env name="DB_URL" value=""/>
        <env name="REDIS_HOST" value="redis_test"/>
        <env name="REDIS_PORT" value="6379"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
        <env name="INERTIA_SSR_ENABLED" value="false"/>
        <!-- Fake Azure config so AnalysisService::autoDispatchEnabled() lets
             dispatch tests fake the bus instead of silently no-op'ing. -->
        <env name="AZURE_OPENAI_URI" value="https://x.openai.azure.com/openai/deployments/x/chat/completions?api-version=2024-10-21"/>
        <env name="AZURE_OPENAI_API_KEY" value="fake-test-key"/>
    </php>
</phpunit>
