			path: app/Services/Gamification/UnlockEngine.php

		-
			message: '#^Offset ''badgeCounts'' on array\{user\: App\\Models\\User, prCount\: int, activityCount\: int, totalDistanceM\: float, rarityCounts\: array\<string, int\>, streakWeeks\: int, twoWeekStreak\: int, tenKPlus\: int\} on left side of \?\? does not exist\.$#'
			identifier: nullCoalesce.offset
