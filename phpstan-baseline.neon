		-
			message: '#^Method App\\Services\\AI\\RuleBased\\RuleBasedInsightBuilder\:\:appendVariabilityCommentPart\(\) has parameter \$parts with no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
