parameters:
	ignoreErrors:
		-
			message: '#^Using nullsafe property access "\?\-\>name" on left side of \?\? is unnecessary\. Use \-\> instead\.$#'
			identifier: nullsafe.neverNull
			count: 1
			path: app/Http/Controllers/TokenUsageController.php

		-
			message: '#^Method App\\Livewire\\Pulse\\StravaHealth\:\:perUserSyncHistory\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: app/Livewire/Pulse/StravaHealth.php

		-
			message: '#^PHPDoc tag @return has invalid value \(list\<array\{user_id\: int, user_name\: string, last_sync\: string\|null, status\: string, 15min_remaining\: int\|null, daily_remaining\: int\|null, is_failed\: bool\}\>\)\: Unexpected token "min_remaining", expected ''\}'' at offset 105 on line 2$#'
			identifier: phpDoc.parseError
			count: 1
			path: app/Livewire/Pulse/StravaHealth.php

		-
			message: '#^Using nullsafe property access "\?\-\>status" on left side of \?\? is unnecessary\. Use \-\> instead\.$#'
			identifier: nullsafe.neverNull
			count: 1
			path: app/Livewire/Pulse/StravaHealth.php

		-
			message: '#^Method App\\Models\\Analytics\\StravaSyncLog\:\:log\(\) has parameter \$rateLimits with no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: app/Models/Analytics/StravaSyncLog.php

		-
			message: '#^PHPDoc tag @param has invalid value \(array\{15min\: int, daily\: int\}\|null  \$rateLimits\)\: Unexpected token "min", expected ''\}'' at offset 169 on line 5$#'
			identifier: phpDoc.parseError
			count: 1
			path: app/Models/Analytics/StravaSyncLog.php

		-
			message: '#^Access to an undefined property App\\Models\\ActivityDetail\:\:\$avg_pace\.$#'
			identifier: property.notFound
