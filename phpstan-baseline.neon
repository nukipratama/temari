		-
			message: '#^Method App\\Services\\AI\\RuleBased\\RuleBasedInsightBuilder\:\:deriveZonePctFromMinutes\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: app/Services/AI/RuleBased/RuleBasedInsightBuilder.php

		-
