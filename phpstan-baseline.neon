			identifier: missingType.iterableValue
			count: 1
			path: app/Services/AI/RuleBased/RuleBasedInsightBuilder.php

		-
			message: '#^Offset ''pace'' on array\{km\: int, pace\: string\} on left side of \?\? always exists and is not nullable\.$#'
			identifier: nullCoalesce.offset
			count: 1
			path: app/Services/AI/RuleBased/RuleBasedInsightBuilder.php

		-
			message: '#^Parameter \#1 \.\.\.\$arg1 of function max expects non\-empty\-array, array\<string, float\> given\.$#'
			identifier: argument.type
			count: 1
			path: app/Services/AI/RuleBased/RuleBasedInsightBuilder.php

		-
